# Copy this file to .env and fill in your keys

# Claude API key — required for "Generate 60 posts" on the approvals page
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn — required only if you want real publishing (leave blank for dry-run mode)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
LINKEDIN_DRY_RUN=false

# Path to your banner images folder (PNG/JPG)
BANNERS_DIR=C:\Users\YourName\Desktop\banners-png

# Publish time slots (24h, comma-separated)
PUBLISH_SLOTS=11:25,18:36
